# J.A.R.V.I.S. Configuration
# Copy this file to .env and fill in your values

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Options: ollama (default, local), openai, anthropic
LLM_PROVIDER=ollama
LLM_MODEL=llama3

# Ollama (local — no API key needed, just run `ollama serve`)
OLLAMA_HOST=http://localhost:11434

# OpenAI (optional — set LLM_PROVIDER=openai to use)
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# Anthropic (optional — set LLM_PROVIDER=anthropic to use)
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-3-5-sonnet-20241022

# ─── Speech Recognition ───────────────────────────────────────────────────────
# Whisper model size: tiny.en, base.en (default), small.en, medium.en
# Larger = more accurate but slower to load
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu   # "cpu" or "cuda" (if you have a GPU)

# ─── Text to Speech ──────────────────────────────────────────────────────────
# Best Jarvis-like voices: en-GB-RyanNeural, en-GB-SoniaNeural, en-US-GuyNeural
# Run `python jarvis.py --list-voices` to see all options
TTS_VOICE=en-GB-RyanNeural

# ─── Wake Word ───────────────────────────────────────────────────────────────
USE_WAKE_WORD=true
# Hotkey fallback (when openwakeword not installed): default is ctrl+shift+j

# ─── Identity ────────────────────────────────────────────────────────────────
USER_TITLE=sir          # How Jarvis addresses you (sir, ma'am, etc.)
USER_NAME=              # Your name (optional — Jarvis will use it)

# ─── Debug ───────────────────────────────────────────────────────────────────
DEBUG=false
