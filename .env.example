# ═══════════════════════════════════════════════════════
#   J.A.R.V.I.S. Configuration
#   Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ── AI Engine ────────────────────────────────────────
# Options: llamacpp (local, offline), groq (free cloud), openrouter
LLM_PROVIDER=llamacpp

# ── Option 1: Local AI (llamacpp) ────────────────────
# No API key needed. Downloads model automatically on first run.
# Model choices: qwen2.5-7b (recommended), llama3.1-8b, qwen2.5-3b, phi4-mini
LLAMACPP_MODEL_ID=qwen2.5-7b

# Set this if you have your own GGUF (skips auto-download):
# LLAMACPP_MODEL_PATH=C:\path\to\your_model.gguf

# GPU acceleration: -1 = all layers on GPU, 0 = CPU only
# If you have an NVIDIA GPU set this to -1 for much faster responses
GPU_LAYERS=-1

# Context window size (larger = more memory)
CONTEXT_SIZE=4096

# ── Option 2: Groq (free, fast, 70B quality) ─────────
# Free account at https://console.groq.com (30 seconds to sign up)
# Runs Llama 3.1 70B at 300+ tokens/sec. Much faster than local.
# To use: set LLM_PROVIDER=groq and add your key below.
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Option 3: OpenRouter (100+ models) ────────────────
# Free account at https://openrouter.ai
# Access Claude 3.5 Sonnet, GPT-4o, Gemini Pro, and many free models.
# To use: set LLM_PROVIDER=openrouter and add your key below.
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct:free

# ── Voice ─────────────────────────────────────────────
# STT model: tiny.en (fastest) → base.en → small.en → medium.en (most accurate)
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu

# Best Jarvis voices: en-GB-RyanNeural, en-GB-SoniaNeural, en-US-GuyNeural
TTS_VOICE=en-GB-RyanNeural

# Set false to skip wake word and always listen
USE_WAKE_WORD=true

# ── Tuning ────────────────────────────────────────────
MAX_TOKENS=512
TEMPERATURE=0.7

# ── Identity ──────────────────────────────────────────
USER_TITLE=sir
USER_NAME=

# ── Debug ─────────────────────────────────────────────
DEBUG=false
